# X Education — User Backend Environment Variables
# Copy this to .env and fill in your real values

# Gmail SMTP (for OTP + marketing emails)
GMAIL_USER=yourname@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# JWT Secret (any long random string — keep secret)
JWT_SECRET=xeducation_super_secret_jwt_key_2025_change_this

# OTP expiry in minutes
OTP_EXPIRY_MINUTES=10

# Cart abandonment check interval (minutes)
CART_CHECK_INTERVAL_MINUTES=5

# Cart abandonment threshold (minutes of inactivity)
CART_ABANDON_THRESHOLD_MINUTES=60
